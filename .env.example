## Django
SECRET_KEY=replace-me
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

## Database (Render/Supabase Postgres)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DB_CONN_MAX_AGE=60

## CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://donareact.vercel.app

## Optional: regex origins (e.g. Vercel previews)
# CORS_ALLOWED_ORIGIN_REGEXES=https://.*\\.vercel\\.app

## Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

## Optional: folder/prefix for uploads
CLOUDINARY_FOLDER=donaciano

